<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ shows a system splash icon by default. Keep the launcher
         logo for the app icon, but make the system splash icon transparent so
         startup branding comes from the launch background instead. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_brand_mark</item>
    </style>
</resources>
